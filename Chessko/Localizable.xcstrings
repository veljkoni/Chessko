    "Samo Kraljevi, ili Kralj + Lovac/Skakač protiv Kralja — nije moguće dati mat. Automatski remi." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur Könige, oder König + Läufer/Springer gegen König — Matt ist unmöglich. Automatisches Remis."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Only kings, or king + bishop/knight against king — checkmate is impossible. Automatic draw."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seuls les rois, ou roi + fou/cavalier contre roi — le mat est impossible. Nulle automatique."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "केवल राजा, या राजा + ऊँट/घोड़ा बनाम राजा — शहमात संभव नहीं। स्वतः ड्रॉ।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo i re, oppure re + alfiere/cavallo contro re — il matto è impossibile. Patta automatica."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Только короли, или король + слон/конь против короля — мат невозможен. Автоматическая ничья."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Samo Kraljevi, ili Kralj + Lovac/Skakač protiv Kralja — nije moguće dati mat. Automatski remi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只剩双王，或王 + 象/马 对王——无法将杀。自动和棋。"
          }
        }
      }
    },
    "Sav sadržaj lekcija preuzet je iz digitalne verzije knjige dostupne na **Project Gutenberg** — neprofitnoj biblioteci knjiga u javnom domenu." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Lektionsinhalte stammen aus der digitalen Version des Buches, verfügbar bei **Project Gutenberg** — einer gemeinnützigen Bibliothek gemeinfreier Bücher."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All lesson content is taken from the digital version of the book available on **Project Gutenberg** — a non-profit library of public-domain books."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tout le contenu des leçons provient de la version numérique du livre disponible sur **Project Gutenberg** — une bibliothèque à but non lucratif d’ouvrages du domaine public."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सभी पाठ सामग्री **Project Gutenberg** पर उपलब्ध पुस्तक के डिजिटल संस्करण से ली गई है — सार्वजनिक डोमेन की पुस्तकों का एक गैर-लाभकारी पुस्तकालय।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tutti i contenuti delle lezioni provengono dalla versione digitale del libro disponibile su **Project Gutenberg** — una biblioteca senza scopo di lucro di libri di pubblico dominio."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Весь материал уроков взят из цифровой версии книги, доступной на **Project Gutenberg** — некоммерческой библиотеке книг в общественном достоянии."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sav sadržaj lekcija preuzet je iz digitalne verzije knjige dostupne na **Project Gutenberg** — neprofitnoj biblioteci knjiga u javnom domenu."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有课程内容均取自 **古腾堡计划** 上提供的该书数字版——一个收录公共领域图书的非营利图书馆。"
          }
        }
      }
