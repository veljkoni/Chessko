    "Jede protivničke figure isključivo po dijagonali jedno polje unapred." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er schlägt gegnerische Figuren nur diagonal, ein Feld nach vorn."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It captures enemy pieces only diagonally, one square ahead."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il capture les pièces adverses uniquement en diagonale, une case en avant."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह विरोधी मोहरों को केवल तिरछे, एक खाना आगे मारता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cattura i pezzi avversari solo in diagonale, una casa in avanti."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Бьёт фигуры противника только по диагонали на одно поле вперёд."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jede protivničke figure isključivo po dijagonali jedno polje unapred."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只能斜向前一格吃子。"
          }
        }
      }
    },
    "Jedina figura koja može da preskače druge figure — i svoje i protivničke!" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die einzige Figur, die über andere Figuren springen kann — eigene wie gegnerische!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The only piece that can jump over other pieces — both its own and the opponent’s!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La seule pièce qui peut sauter par-dessus d’autres pièces — les siennes comme celles de l’adversaire !"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एकमात्र मोहरा जो अन्य मोहरों के ऊपर से कूद सकता है — अपने और विरोधी दोनों के!"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’unico pezzo che può saltare altri pezzi — sia i propri sia quelli avversari!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Единственная фигура, которая может перепрыгивать через другие — и свои, и чужие!"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jedina figura koja može da preskače druge figure — i svoje i protivničke!"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "唯一能跳过其他棋子的棋子——无论己方还是对方！"
          }
        }
      }
    },
    "Jedina figura koja preskače ostale. Snažan je u **zatvorenim pozicijama** — kada su linije blokirane pionima. Na ivici table gubi na snazi." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die einzige Figur, die über andere springt. Er ist stark in **geschlossenen Stellungen** — wenn die Linien von Bauern blockiert sind. Am Brettrand verliert er an Stärke."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The only piece that jumps over others. It is strong in **closed positions** — when the lines are blocked by pawns. On the edge of the board it loses strength."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La seule pièce qui saute par-dessus les autres. Il est fort dans les **positions fermées** — quand les lignes sont bloquées par des pions. Au bord de l’échiquier, il perd de sa force."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एकमात्र मोहरा जो दूसरों के ऊपर से कूदता है। यह **बंद स्थितियों** में मजबूत है — जब लाइनें प्यादों से अवरुद्ध हों। बोर्ड के किनारे पर यह कमजोर हो जाता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’unico pezzo che salta gli altri. È forte nelle **posizioni chiuse** — quando le linee sono bloccate dai pedoni. Sul bordo della scacchiera perde forza."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Единственная фигура, перепрыгивающая через другие. Силён в **закрытых позициях** — когда линии перекрыты пешками. На краю доски теряет силу."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jedina figura koja preskače ostale. Snažan je u **zatvorenim pozicijama** — kada su linije blokirane pionima. Na ivici table gubi na snazi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "唯一能跳过其他棋子的棋子。它在**封闭局面**中很强——当线路被兵堵住时。在棋盘边缘则会减弱。"
          }
        }
      }
    },
    "Jedinstven!" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einzigartig!"
          }
        },
        "en" : {
