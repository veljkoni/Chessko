    },
    "Kombinuje kretanje Topa i Lovca — kreće se u svim pravcima, koliko god polja želi." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie verbindet die Bewegung von Turm und Läufer — in alle Richtungen, beliebig weit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It combines the rook’s and bishop’s movement — moving in all directions, as many squares as it likes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elle combine les déplacements de la tour et du fou — dans toutes les directions, autant de cases qu’elle veut."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह हाथी और ऊँट की चाल को मिलाता है — सभी दिशाओं में, जितने चाहे खाने।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Combina il movimento di torre e alfiere — in tutte le direzioni, per quante case vuole."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сочетает ход ладьи и слона — двигается во всех направлениях на любое число полей."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kombinuje kretanje Topa i Lovca — kreće se u svim pravcima, koliko god polja želi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "它兼具车和象的走法——可向任意方向走任意格数。"
          }
        }
      }
    },
