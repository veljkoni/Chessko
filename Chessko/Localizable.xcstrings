    "Greet – Hanley, Liverpool 2008. Dama se žrtvuje na h6. Zašto Kralj mora da uzme?" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Greet – Hanley, Liverpool 2008. Die Dame opfert sich auf h6. Warum muss der König schlagen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Greet – Hanley, Liverpool 2008. The queen is sacrificed on h6. Why must the king take?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Greet – Hanley, Liverpool 2008. La dame se sacrifie en h6. Pourquoi le roi doit-il prendre ?"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ग्रीट – हैनली, लिवरपूल 2008। वज़ीर h6 पर बलिदान होता है। राजा को लेना क्यों पड़ता है?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Greet – Hanley, Liverpool 2008. La donna si sacrifica in h6. Perché il re deve prendere?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Грит – Хэнли, Ливерпуль 2008. Ферзь жертвуется на h6. Почему король обязан взять?"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Greet – Hanley, Liverpool 2008. Dama se žrtvuje na h6. Zašto Kralj mora da uzme?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Greet – Hanley，利物浦 2008。后在 h6 弃身。为什么国王必须吃？"
          }
        }
      }
    },
