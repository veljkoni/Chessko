          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "国王"
          }
        }
      }
    },
    "Kralj je napadnut, a nema nijedan legalan način odbrane. Partija se završava ovde — Kralj se nikada zapravo ne jede." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der König wird angegriffen und es gibt keine legale Verteidigung. Die Partie endet hier — der König wird nie tatsächlich geschlagen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The king is under attack and there is no legal way to defend. The game ends here — the king is never actually captured."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le roi est attaqué et il n’y a aucun moyen légal de se défendre. La partie se termine ici — le roi n’est jamais réellement capturé."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "राजा पर हमला है और बचाव का कोई वैध तरीका नहीं। खेल यहीं समाप्त होता है — राजा वास्तव में कभी नहीं मारा जाता।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il re è sotto attacco e non c’è alcun modo legale di difendersi. La partita finisce qui — il re non viene mai realmente catturato."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Король под атакой, и нет ни одного законного способа защититься. Партия заканчивается — короля никогда фактически не бьют."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kralj je napadnut, a nema nijedan legalan način odbrane. Partija se završava ovde — Kralj se nikada zapravo ne jede."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "国王被攻击，且没有任何合法的防御办法。对局到此结束——国王实际上永远不会被吃掉。"
          }
        }
      }
    },
    "Kralj postaje napadač" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der König wird zum Angreifer"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The king becomes an attacker"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le roi devient attaquant"
