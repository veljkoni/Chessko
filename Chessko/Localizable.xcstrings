    "Odigraj svaki potez belih na tabli — crni odgovara automatski po teorijskoj liniji." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spiele jeden Zug von Weiß auf dem Brett — Schwarz antwortet automatisch nach der theoretischen Linie."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play each of White’s moves on the board — Black replies automatically along the theoretical line."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jouez chaque coup des Blancs sur l’échiquier — les Noirs répondent automatiquement selon la ligne théorique."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "बोर्ड पर सफ़ेद की हर चाल खेलें — काला सैद्धांतिक लाइन के अनुसार स्वतः जवाब देता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gioca ogni mossa del Bianco sulla scacchiera — il Nero risponde automaticamente seguendo la linea teorica."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сыграйте каждый ход белых на доске — чёрные отвечают автоматически по теоретической линии."
