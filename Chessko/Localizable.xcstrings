    "Postavi ih na otvorenu kolonu ili sedmi red. Top zatvoren iza sopstvenih piona je pasivna figura." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stelle sie auf eine offene Linie oder die siebte Reihe. Ein Turm, der hinter den eigenen Bauern eingesperrt ist, ist eine passive Figur."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Place them on an open file or the seventh rank. A rook shut in behind its own pawns is a passive piece."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Placez-les sur une colonne ouverte ou la septième rangée. Une tour enfermée derrière ses propres pions est une pièce passive."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उन्हें खुली फाइल या सातवीं रैंक पर रखें। अपने ही प्यादों के पीछे बंद हाथी एक निष्क्रिय मोहरा है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mettile su una colonna aperta o sulla settima traversa. Una torre chiusa dietro i propri pedoni è un pezzo passivo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ставьте их на открытую линию или седьмую горизонталь. Ладья, запертая за собственными пешками, — пассивная фигура."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Postavi ih na otvorenu kolonu ili sedmi red. Top zatvoren iza sopstvenih piona je pasivna figura."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "把它们放在开放线或第七横线上。被自己兵困住的车是被动棋子。"
          }
        }
      }
    },
