    "Oteraj crnog Kralja na ivicu table. Top i Kralj moraju da sarađuju!" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Treibe den schwarzen König an den Brettrand. Turm und König müssen zusammenarbeiten!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drive the black king to the edge of the board. Rook and king must cooperate!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Repoussez le roi noir au bord de l’échiquier. La tour et le roi doivent coopérer !"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "काले राजा को बोर्ड के किनारे की ओर धकेलें। हाथी और राजा को मिलकर काम करना होगा!"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spingi il re nero sul bordo della scacchiera. Torre e re devono collaborare!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оттесните чёрного короля к краю доски. Ладья и король должны действовать вместе!"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oteraj crnog Kralja na ivicu table. Top i Kralj moraju da sarađuju!"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "把黑王逼到棋盘边缘。车和王必须配合！"
          }
        }
      }
    },
    "Oteraj Kralja ne samo na ivicu već i u ugao iste boje kao tvoji lovci." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Treibe den König nicht nur an den Rand, sondern in eine Ecke der gleichen Farbe wie deine Läufer."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drive the king not only to the edge but into a corner of the same colour as your bishops."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Repoussez le roi non seulement au bord mais dans un coin de la même couleur que vos fous."
