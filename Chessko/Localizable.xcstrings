            "state" : "translated",
            "value" : "车"
          }
        }
      }
    },
    "Top ide na e8 i daje šah. Crni Top mora da uzme — a onda Dama?" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Turm geht mit Schach nach e8. Der schwarze Turm muss schlagen — und dann die Dame?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The rook goes to e8 with check. The black rook must take — and then the queen?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tour va en e8 avec échec. La tour noire doit prendre — et ensuite la dame ?"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "हाथी शह देते हुए e8 पर जाता है। काले हाथी को लेना ही होगा — और फिर वज़ीर?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La torre va in e8 con scacco. La torre nera deve prendere — e poi la donna?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ладья идёт на e8 с шахом. Чёрная ладья обязана взять — а затем ферзь?"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Top ide na e8 i daje šah. Crni Top mora da uzme — a onda Dama?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "车到 e8 将军。黑车必须吃——然后是后？"
          }
        }
      }
    },
    "Top vredi kao skakač plus dva piona" : {
