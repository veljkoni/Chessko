    "Primeni sve što si naučio! Reši 5 zadataka — mat u najmanji broj poteza. Svaki koristi drugu kombinaciju figura." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wende alles an, was du gelernt hast! Löse 5 Aufgaben — Matt in möglichst wenigen Zügen. Jede nutzt eine andere Figurenkombination."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apply everything you’ve learned! Solve 5 puzzles — mate in the fewest moves. Each uses a different combination of pieces."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appliquez tout ce que vous avez appris ! Résolvez 5 problèmes — mat en un minimum de coups. Chacun utilise une combinaison de pièces différente."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जो कुछ सीखा है उसे लागू करें! 5 पहेलियाँ हल करें — सबसे कम चालों में मात। हर एक में मोहरों का अलग संयोजन है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applica tutto ciò che hai imparato! Risolvi 5 problemi — matto nel minor numero di mosse. Ognuno usa una diversa combinazione di pezzi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Примените всё, что узнали! Решите 5 задач — мат в наименьшее число ходов. В каждой своя комбинация фигур."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Primeni sve što si naučio! Reši 5 zadataka — mat u najmanji broj poteza. Svaki koristi drugu kombinaciju figura."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "运用你学到的一切！解开 5 道谜题——用最少的步数将杀。每道使用不同的棋子组合。"
          }
        }
      }
    },
