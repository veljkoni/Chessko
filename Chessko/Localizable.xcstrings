        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "राजा को केवल किनारे ही नहीं, बल्कि अपने ऊँटों के रंग के कोने में धकेलें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
