    "Kralj u završnici postaje napadačka figura" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Im Endspiel wird der König zur Angriffsfigur"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In the endgame the king becomes an attacking piece"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En finale, le roi devient une pièce d’attaque"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अंत खेल में राजा एक हमलावर मोहरा बन जाता है"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nel finale il re diventa un pezzo d’attacco"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В эндшпиле король становится атакующей фигурой"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
