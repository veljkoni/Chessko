    "Situacija kada je Kralj napadnut. Igrač **mora** da se odbrani — pomeri kralja, pojede napadača, ili postavi štit između." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Situation, in der der König angegriffen wird. Der Spieler **muss** sich verteidigen — den König ziehen, den Angreifer schlagen oder einen Schild dazwischenstellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A situation where the king is under attack. The player **must** defend — move the king, capture the attacker, or place a shield in between."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une situation où le roi est attaqué. Le joueur **doit** se défendre — déplacer le roi, capturer l’attaquant, ou interposer un bouclier."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ऐसी स्थिति जब राजा पर हमला हो। खिलाड़ी को **अवश्य** बचाव करना होगा — राजा हिलाएँ, हमलावर को मारें, या बीच में ढाल रखें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una situazione in cui il re è sotto attacco. Il giocatore **deve** difendersi — muovere il re, catturare l’attaccante o frapporre uno scudo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ситуация, когда король под атакой. Игрок **обязан** защититься — увести короля, побить нападающего или поставить заслон."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Situacija kada je Kralj napadnut. Igrač **mora** da se odbrani — pomeri kralja, pojede napadača, ili postavi štit između."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "国王受到攻击的局面。该方**必须**应对——移动国王、吃掉攻击者，或在中间放置屏障。"
          }
        }
      }
    },
