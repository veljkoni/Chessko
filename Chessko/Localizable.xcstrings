    "Lovac daje šah i tera Kralja na g8. Zašto je to pogubno?" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Läufer gibt Schach und treibt den König nach g8. Warum ist das verhängnisvoll?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The bishop gives check and drives the king to g8. Why is that fatal?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le fou fait échec et pousse le roi en g8. Pourquoi est-ce fatal ?"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ऊँट शह देकर राजा को g8 पर धकेलता है। यह घातक क्यों है?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’alfiere dà scacco e spinge il re in g8. Perché è fatale?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Слон даёт шах и гонит короля на g8. Почему это губительно?"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lovac daje šah i tera Kralja na g8. Zašto je to pogubno?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "象将军，把国王逼到 g8。为什么这是致命的？"
          }
        }
      }
    },
    "Lovac je jači kada su pioni na obe strane" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Läufer ist stärker, wenn auf beiden Seiten Bauern stehen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The bishop is stronger when pawns are on both sides"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le fou est plus fort quand il y a des pions des deux côtés"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जब प्यादे दोनों ओर हों तो ऊँट अधिक मजबूत होता है"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’alfiere è più forte quando ci sono pedoni su entrambi i lati"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Слон сильнее, когда пешки на обоих флангах"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lovac je jači kada su pioni na obe strane"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "兵在两侧时象更强"
          }
        }
      }
    },
    "Lovac je naročito snažan kada postoje pioni na obe strane table i kada su linije otvorene." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Läufer ist besonders stark, wenn auf beiden Seiten Bauern stehen und die Linien offen sind."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The bishop is especially strong when there are pawns on both sides of the board and the lines are open."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le fou est particulièrement fort lorsqu’il y a des pions des deux côtés et que les lignes sont ouvertes."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ऊँट तब विशेष रूप से मजबूत होता है जब बोर्ड के दोनों ओर प्यादे हों और लाइनें खुली हों।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’alfiere è particolarmente forte quando ci sono pedoni su entrambi i lati e le linee sono aperte."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Слон особенно силён, когда пешки есть на обоих флангах и линии открыты."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lovac je naročito snažan kada postoje pioni na obe strane table i kada su linije otvorene."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当棋盘两侧都有兵且线路开放时，象尤为强大。"
          }
        }
      }
    },
    "Lovac koji blokira sopstveni pion je ograničen. Pione postavljaj na polja **suprotne boje** od svog lovca." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein vom eigenen Bauern blockierter Läufer ist eingeschränkt. Stelle deine Bauern auf Felder der **Gegenfarbe** deines Läufers."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A bishop blocked by its own pawn is limited. Put your pawns on squares of the **opposite colour** to your bishop."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un fou bloqué par son propre pion est limité. Placez vos pions sur des cases de **couleur opposée** à votre fou."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने ही प्यादे से अवरुद्ध ऊँट सीमित होता है। अपने प्यादों को अपने ऊँट के **विपरीत रंग** के खानों पर रखें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un alfiere bloccato dal proprio pedone è limitato. Metti i pedoni su case di **colore opposto** al tuo alfiere."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Слон, заблокированный собственной пешкой, ограничен. Ставьте пешки на поля **противоположного цвета** относительно вашего слона."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lovac koji blokira sopstveni pion je ograničen. Pione postavljaj na polja **suprotne boje** od svog lovca."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "被自己兵挡住的象会受限。把你的兵放在与你象**异色**的格子上。"
          }
        }
      }
    },
    "Lovac može istovremeno da napada pione na oba krila zahvaljujući dometu. Skakač je spor i ne može da stigne svuda." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dank seiner Reichweite kann der Läufer Bauern auf beiden Flügeln gleichzeitig angreifen. Der Springer ist langsam und kann nicht überallhin gelangen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thanks to its range the bishop can attack pawns on both wings at once. The knight is slow and cannot reach everywhere."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grâce à sa portée, le fou peut attaquer des pions sur les deux ailes à la fois. Le cavalier est lent et ne peut pas être partout."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपनी पहुँच के कारण ऊँट एक साथ दोनों किनारों के प्यादों पर हमला कर सकता है। घोड़ा धीमा है और हर जगह नहीं पहुँच सकता।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grazie alla sua gittata l’alfiere può attaccare pedoni su entrambe le ali contemporaneamente. Il cavallo è lento e non può arrivare ovunque."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Благодаря дальнобойности слон может атаковать пешки на обоих флангах одновременно. Конь медлителен и не успевает повсюду."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lovac može istovremeno da napada pione na oba krila zahvaljujući dometu. Skakač je spor i ne može da stigne svuda."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "凭借射程，象能同时攻击两翼的兵。马很慢，无法兼顾各处。"
          }
        }
      }
    },
