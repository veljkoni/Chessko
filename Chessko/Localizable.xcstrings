    "Završnica počinje kada su sa table nestale najvažnije figure i ostanu Kraljevi sa pešacima i možda jednom-dve lake figure." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Endspiel beginnt, wenn die wichtigsten Figuren das Brett verlassen haben und nur die Könige mit Bauern und vielleicht ein oder zwei Leichtfiguren bleiben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The endgame begins when the most important pieces have left the board and only the kings remain with pawns and perhaps one or two minor pieces."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La finale commence quand les pièces les plus importantes ont quitté l’échiquier et qu’il ne reste que les rois avec des pions et peut-être une ou deux pièces mineures."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अंत खेल तब शुरू होता है जब सबसे महत्वपूर्ण मोहरे बोर्ड से चले जाते हैं और केवल राजा, प्यादों और शायद एक-दो छोटे मोहरों के साथ बचते हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il finale inizia quando i pezzi più importanti hanno lasciato la scacchiera e restano solo i re con i pedoni e forse uno o due pezzi minori."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Эндшпиль начинается, когда важнейшие фигуры покинули доску и остаются короли с пешками и, возможно, одной-двумя лёгкими фигурами."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Završnica počinje kada su sa table nestale najvažnije figure i ostanu Kraljevi sa pešacima i možda jednom-dve lake figure."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当最重要的棋子离开棋盘，只剩下双王、兵以及或许一两个轻子时，残局便开始了。"
          }
        }
      }
    },
